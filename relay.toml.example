# relay.toml — self-hosted Relay Server config (no relay.md dependency)
#
# Generate server auth material with:
#   docker compose run --rm relay-server /app/relay gen-auth --json --key-type EdDSA
# Put the returned auth_token in .env as RELAY_SERVER_AUTH, and put the
# returned public_key in the first [[auth]] block below.
#
# Then generate a legacy HMAC key with ./keygen.sh and put it in the second
# [[auth]] block. relay-server uses that key to sign returned doc/file tokens.

[server]
url = "http://localhost:8080"
host = "0.0.0.0"
port = 8080

[logging]
level = "info"
format = "pretty"

[[auth]]
key_id = "self_hosted"
key_type = "EdDSA"
public_key = "REPLACE_WITH_EDDSA_PUBLIC_KEY"
allowed_token_types = ["document", "file", "server", "prefix"]

[[auth]]
key_id = "self_hosted_legacy"
key_type = "hmac-sha256"
private_key = "REPLACE_WITH_OUTPUT_OF_KEYGEN_SH"
allowed_token_types = ["document", "file", "server", "prefix"]

[store]
type = "filesystem"
path = "/app/data"
