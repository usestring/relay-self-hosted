# relay.toml — self-hosted Relay Server config (no relay.md dependency)
#
# Generate auth material with:
#   docker compose run --rm relay-server /app/relay gen-auth --json --key-type legacy
# Put the returned server_token in .env as RELAY_SERVER_AUTH, and put the
# returned key_id/private_key in the [[auth]] block below.

[server]
url = "http://localhost:8080"
host = "0.0.0.0"
port = 8080

[logging]
level = "info"
format = "pretty"

[[auth]]
key_id = "REPLACE_WITH_GENERATED_KEY_ID"
key_type = "legacy"
private_key = "REPLACE_WITH_GENERATED_PRIVATE_KEY"
allowed_token_types = ["document", "file", "server", "prefix"]

[store]
type = "filesystem"
path = "/app/data"
